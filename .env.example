POSTGRES_USER=emailhub
POSTGRES_PASSWORD=emailhub_dev
POSTGRES_DB=emailhub
# Leave empty so Docker compose derives this from POSTGRES_USER/PASSWORD/DB.
DATABASE_URL=

API_PORT=8080
API_BIND=127.0.0.1:8080
WEB_BIND=127.0.0.1:5173
EMAILHUB_API_BASE_URL=http://127.0.0.1:8080
EMAILHUB_WEB_BASE_URL=http://127.0.0.1:5173
# Optional Docker Compose project name. Leave empty to derive it from the repo
# directory; set a unique value when running multiple Email Hub checkouts.
EMAILHUB_DOCKER_COMPOSE_PROJECT_NAME=
EMAILHUB_DOCKER_HEALTH_TIMEOUT_MS=5000
EMAILHUB_DOCKER_HEALTH_ATTEMPTS=12
EMAILHUB_DOCKER_HEALTH_WAIT_MS=5000
NODE_ENV=development
LOG_LEVEL=info
DIAGNOSTICS_LOG_CAPACITY=500
# Protect all /api/* routes except /health, EmailEngine webhook, and auth-server.
# Use the same value for VITE_EMAILHUB_API_TOKEN when the static web app calls
# the API directly from a trusted self-hosted browser session.
EMAILHUB_API_TOKEN=
# Optional comma-separated account ids that this token may access. Leave empty
# for the self-hosted admin token to access every connected account.
EMAILHUB_API_TOKEN_ACCOUNT_IDS=
EMAILHUB_REQUIRE_API_TOKEN=false
# Keep true only for local/dev compose. Production overlay forces false.
EMAILHUB_ALLOW_DEV_SECRETS=true
VITE_EMAILHUB_API_TOKEN=
# Optional account id used by the bundled web app when EMAILHUB_API_TOKEN_ACCOUNT_IDS
# restricts the browser token to one account.
VITE_EMAILHUB_DEFAULT_ACCOUNT_ID=
EMAILHUB_ATTACHMENT_DOWNLOAD_MAX_BYTES=26214400
# Native Engine is paused for the EmailEngine-first launch. Keep this false for
# Docker self-hosting unless intentionally running legacy native-engine tests.
EMAILHUB_NATIVE_ENGINE_ENABLED=false
EMAILHUB_NOFILE_SOFT=65535
EMAILHUB_NOFILE_HARD=65535
COMPOSE_ATTACHMENT_BLOB_DIR=/data/email-hub/compose-attachments
# Local compose upload blobs are retained while active drafts/outbox items refer
# to them. Unreferenced blobs older than this are pruned by the worker.
COMPOSE_ATTACHMENT_CLEANUP_RETENTION_HOURS=168
COMPOSE_ATTACHMENT_CLEANUP_INTERVAL_MS=3600000
COMPOSE_ATTACHMENT_CLEANUP_LIMIT=100
# Hermes skill run/audit/cache records may include truncated mail context.
# Keep retention bounded on small self-hosted machines.
HERMES_RETENTION_DAYS=30
HERMES_RETENTION_CLEANUP_INTERVAL_MS=3600000
HERMES_RETENTION_CLEANUP_LIMIT=500
# Pin EmailEngine for repeatable self-hosted launches. Override with a newer
# version tag or immutable digest only after running the launch verifier.
EMAILENGINE_IMAGE=postalsys/emailengine:v2.71.0@sha256:4f732fd40e39f8e3af0b3d1580f1972a7e7270741be510f217a6b07eac5b0efc
EMAILENGINE_URL=http://emailengine:3000
# Required for EmailEngine-backed onboarding, attachment download, send, and sync.
# Leave empty only when testing native-only paths or UI without real IMAP/SMTP accounts.
EMAILENGINE_ACCESS_TOKEN=
EMAILENGINE_WEBHOOK_SECRET=dev-emailhub-secret
EMAILENGINE_WEBHOOK_MAX_SKEW_SECONDS=600
EMAILENGINE_WEBHOOK_URL=http://api:8080/api/webhooks/emailengine
EMAILENGINE_AUTH_SERVER_SECRET=dev-emailhub-secret
# Leave empty so Docker compose derives this from EMAILENGINE_AUTH_SERVER_SECRET.
EMAILENGINE_AUTH_SERVER_URL=
EENGINE_SECRET=dev-emailhub-secret
# Export this from EmailEngine's prepared token flow for unattended Docker startup.
# It must represent the same raw token configured in EMAILENGINE_ACCESS_TOKEN.
EENGINE_PREPARED_TOKEN=

# Optional smoke-test mailbox used with infra/docker-compose.test.yml GreenMail.
# Leave the mailbox email unset for fresh-state launch smokes. Set it only when
# intentionally reusing a fixed test mailbox.
# EMAILHUB_SMOKE_MAIL_EMAIL=fixed-smoke@example.com
EMAILHUB_SMOKE_MAIL_PROVIDER=custom_domain
EMAILHUB_SMOKE_MAIL_DISPLAY_NAME=Smoke Mailbox
EMAILHUB_SMOKE_MAIL_SECRET=smoke-secret
# EMAILHUB_SMOKE_RECIPIENT_EMAIL=recipient@example.com
EMAILHUB_SMOKE_RECIPIENT_PROVIDER=custom_domain
EMAILHUB_SMOKE_RECIPIENT_DISPLAY_NAME=Smoke Recipient
EMAILHUB_SMOKE_RECIPIENT_SECRET=smoke-secret
EMAILHUB_SMOKE_IMAP_HOST=greenmail-test
EMAILHUB_SMOKE_IMAP_PORT=3143
EMAILHUB_SMOKE_IMAP_SECURE=false
EMAILHUB_SMOKE_SMTP_HOST=greenmail-test
EMAILHUB_SMOKE_SMTP_PORT=3025
EMAILHUB_SMOKE_SMTP_SECURE=false
EMAILHUB_SMOKE_DELIVERY_SMTP_HOST=127.0.0.1
EMAILHUB_SMOKE_DELIVERY_SMTP_PORT=3025
EMAILHUB_SMOKE_DELIVERY_SMTP_SECURE=false
EMAILHUB_SMOKE_ACCOUNT_ID=11111111-1111-4111-8111-111111111111
EMAILHUB_SMOKE_WEBHOOK_EVENT=emailhubSmokeProbe
EMAILHUB_REAL_WEBHOOK_SMOKE_INITIAL_SYNC_ATTEMPTS=180
EMAILHUB_REAL_WEBHOOK_SMOKE_INITIAL_SYNC_POLL_MS=2000
EMAILHUB_REAL_WEBHOOK_SMOKE_REUSE_EXISTING_ACCOUNT=false
EMAILHUB_REAL_WEBHOOK_SMOKE_ATTEMPTS=60
EMAILHUB_REAL_WEBHOOK_SMOKE_POLL_MS=2000
EMAILHUB_SEND_SMOKE_REUSE_EXISTING_ACCOUNT=false
EMAILHUB_SEND_SMOKE_ATTEMPTS=60
EMAILHUB_SEND_SMOKE_POLL_MS=2000
EMAILHUB_ATTACHMENT_SMOKE_REUSE_EXISTING_ACCOUNT=false
EMAILHUB_ATTACHMENT_SMOKE_ATTEMPTS=60
EMAILHUB_ATTACHMENT_SMOKE_POLL_MS=2000
EMAILHUB_MAIL_ACTION_SMOKE_REUSE_EXISTING_ACCOUNT=false
EMAILHUB_MAIL_ACTION_SMOKE_ATTEMPTS=60
EMAILHUB_MAIL_ACTION_SMOKE_POLL_MS=2000
EMAILHUB_MAIL_ACTION_SMOKE_WORKER_DIAGNOSTIC_ATTEMPTS=60
EMAILHUB_MAIL_ACTION_SMOKE_WORKER_DIAGNOSTIC_POLL_MS=2000
GREENMAIL_SMTP_BIND=127.0.0.1:3025
GREENMAIL_IMAP_BIND=127.0.0.1:3143
# Auth-enabled GreenMail service used by smoke:imap-smtp-onboarding:auth.
# The account is fixed in infra/docker-compose.test.yml:
# emailhub-auth-smoke@example.com / emailhub-auth-secret, with full-email login.
GREENMAIL_AUTH_SMTP_BIND=127.0.0.1:4025
GREENMAIL_AUTH_IMAP_BIND=127.0.0.1:4143
POSTGRES_TEST_BIND=127.0.0.1:55432

# Proton Bridge runs on the Docker host while EmailEngine runs in a container.
PROTON_BRIDGE_HOST=host.docker.internal
PROTON_BRIDGE_IMAP_PORT=1143
PROTON_BRIDGE_SMTP_PORT=1025

WORKER_LEASE_SECONDS=60
WORKER_CONCURRENCY=4
WORKER_POLL_MS=5000
# Local/dev defaults keep the worker runnable while EmailEngine is being prepared.
# infra/docker-compose.prod.yml sets this to true and requires both
# EMAILENGINE_ACCESS_TOKEN and EENGINE_PREPARED_TOKEN.
WORKER_HEALTH_REQUIRE_EMAILENGINE_TOKEN=false

# Optional alias forwarding handoff. When empty, the worker leaves
# alias_delivery_jobs queued instead of claiming and failing them.
ALIAS_DELIVERY_WEBHOOK_URL=

# Native Gmail read-only sync. Refresh tokens are stored per account through
# account_credentials.secret_ref, for example env:GMAIL_REFRESH_TOKEN_ACC_1.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_OAUTH_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
GMAIL_PROFILE_URL=https://gmail.googleapis.com/gmail/v1/users/me/profile
GMAIL_API_BASE_URL=https://gmail.googleapis.com/gmail/v1
# EmailEngine OAuth2 app id for the Gmail API backend.
EMAILENGINE_GMAIL_OAUTH2_PROVIDER_ID=

MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common
MICROSOFT_OAUTH_TOKEN_URL=https://login.microsoftonline.com/common/oauth2/v2.0/token
MICROSOFT_OAUTH_AUTHORIZATION_URL=https://login.microsoftonline.com/common/oauth2/v2.0/authorize
MICROSOFT_GRAPH_PROFILE_URL=https://graph.microsoft.com/v1.0/me
MICROSOFT_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
MICROSOFT_GRAPH_SCOPE=offline_access https://graph.microsoft.com/Mail.ReadWrite https://graph.microsoft.com/Mail.Send https://graph.microsoft.com/Mail.Send.Shared
# EmailEngine OAuth2 app id for the Microsoft Graph API backend.
EMAILENGINE_OUTLOOK_OAUTH2_PROVIDER_ID=

# Hermes-compatible chat completions endpoint. Keep AI access behind Hermes;
# the web app should call /api/hermes/skills/*, not provider APIs directly.
# Examples:
# - Hermes service: HERMES_PROVIDER=hermes, HERMES_CHAT_COMPLETIONS_URL=http://hermes:8081/v1/chat/completions
# - LiteLLM gateway: HERMES_PROVIDER=litellm, HERMES_CHAT_COMPLETIONS_URL=http://litellm:4000/v1/chat/completions
# - Ollama local: HERMES_PROVIDER=ollama, HERMES_CHAT_COMPLETIONS_URL=http://host.docker.internal:11434/v1/chat/completions
# - OpenAI Responses: HERMES_PROVIDER=openai-responses, HERMES_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/responses
# - Responses-style local endpoint: HERMES_PROVIDER=openai-responses, HERMES_CHAT_COMPLETIONS_URL=http://host.docker.internal:11434/v1/responses
HERMES_PROVIDER=hermes
HERMES_CHAT_COMPLETIONS_URL=
HERMES_API_KEY=
HERMES_MODEL=hermes-email
# Optional JSON endpoint returning {"latestVersion":"x.y.z"} for Hermes update checks.
HERMES_VERSION_CHECK_URL=
