{
  "name": "@email-hub/worker-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "diagnostics:sync-jobs": "node dist/sync-job-diagnostics.js",
    "healthcheck": "node dist/healthcheck.js",
    "stress:sync-queue": "node dist/sync-queue-stress.js",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:postgres": "vitest run tests/postgresSyncQueueStress.integration.test.ts",
    "test:postgres:strict": "tsx src/postgres-strict-gate.ts && vitest run tests/postgresSyncQueueStress.integration.test.ts"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "imapflow": "^1.4.0",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
